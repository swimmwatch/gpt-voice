{
  "name": "gpt-voice",
  "version": "1.0.0",
  "description": "Desktop voice transcriber with ChatGPT",
  "homepage": "https://github.com/swimmwatch/gpt-voice",
  "author": {
    "name": "Dmitry Vasiliev",
    "email": "contact.vasiliev.dmitry@gmail.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "start:prod": "npm run build:prod && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "prepare:cloakbrowser": "node scripts/prepare-cloakbrowser.mjs",
    "smoke:cloakbrowser": "node scripts/smoke-cloakbrowser.mjs",
    "collect:release-artifacts": "node scripts/collect-release-artifacts.mjs",
    "pack": "npm run build:prod && npm run prepare:cloakbrowser && electron-builder --dir",
    "dist": "npm run build:prod && npm run prepare:cloakbrowser && electron-builder",
    "dist:linux": "npm run build:prod && npm run prepare:cloakbrowser -- --target=linux && electron-builder --linux",
    "dist:win": "npm run build:prod && npm run prepare:cloakbrowser -- --target=win32 && electron-builder --win",
    "dist:mac": "npm run build:prod && npm run prepare:cloakbrowser -- --target=darwin && electron-builder --mac",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "typecheck": "tsc --noEmit",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "validate:dependabot": "node scripts/validate-dependabot-config.mjs",
    "verify:packaged": "node scripts/verify-packaged-runtime.mjs",
    "verify:installers": "node scripts/verify-installers.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,html}\""
  },
  "keywords": [],
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "commonjs",
  "build": {
    "appId": "com.gptvoice.app",
    "productName": "GPT-Voice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/cloakbrowser/**/*",
      "node_modules/tar/**/*",
      "node_modules/@isaacs/fs-minipass/**/*",
      "node_modules/chownr/**/*",
      "node_modules/minipass/**/*",
      "node_modules/minizlib/**/*",
      "node_modules/mkdirp/**/*",
      "node_modules/yallist/**/*",
      "node_modules/electron-log/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": ".cache/cloakbrowser",
        "to": "cloakbrowser"
      }
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": false,
      "grantFileProtocolExtraPrivileges": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icons",
      "maintainer": "Dmitry Vasiliev <contact.vasiliev.dmitry@gmail.com>",
      "desktop": {
        "entry": {
          "StartupWMClass": "gpt-voice"
        }
      }
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "GPT-Voice",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "cloakbrowser": "0.3.28",
    "electron-log": "^5.4.4",
    "http-status-codes": "^2.3.0",
    "playwright-core": "1.60.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.8.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^41.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "prettier": "^3.8.3",
    "sass": "^1.99.0",
    "sass-loader": "^16.0.8",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.7",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.59.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "yaml": "^2.9.0"
  }
}
