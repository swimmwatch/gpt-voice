{
  "name": "gpt-voice",
  "version": "1.2.0",
  "private": true,
  "description": "Desktop voice transcription app powered by GPT web sessions and OpenAI API.",
  "homepage": "https://github.com/swimmwatch/gpt-voice",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swimmwatch/gpt-voice.git"
  },
  "bugs": {
    "url": "https://github.com/swimmwatch/gpt-voice/issues"
  },
  "author": {
    "name": "Dmitry Vasiliev",
    "email": "contact.vasiliev.dmitry@gmail.com"
  },
  "main": "dist/main.js",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "start:prod": "npm run build:prod && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "ci:install": "node scripts/ci-install.mjs",
    "apply:release-version": "node scripts/apply-release-version.mjs",
    "prepare:cloakbrowser": "node scripts/prepare-cloakbrowser.mjs",
    "generate:package-metadata": "node scripts/generate-package-metadata.mjs",
    "smoke:cloakbrowser": "node scripts/smoke-cloakbrowser.mjs",
    "smoke:fedora": "node scripts/build-fedora-release.mjs --mode=smoke",
    "collect:release-artifacts": "node scripts/collect-release-artifacts.mjs",
    "pack": "npm run build:prod && npm run prepare:cloakbrowser && npm run generate:package-metadata && electron-builder --dir",
    "dist": "npm run build:prod && npm run prepare:cloakbrowser && npm run generate:package-metadata && electron-builder",
    "dist:linux": "npm run build:prod && npm run prepare:cloakbrowser -- --target=linux && npm run generate:package-metadata && electron-builder --linux",
    "dist:fedora": "node scripts/build-fedora-release.mjs --mode=release",
    "dist:win": "npm run build:prod && npm run prepare:cloakbrowser -- --target=win32 && npm run generate:package-metadata && electron-builder --win",
    "dist:mac": "npm run build:prod && npm run prepare:cloakbrowser -- --target=darwin && npm run generate:package-metadata && electron-builder --mac",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\"",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "validate:dependabot": "node scripts/validate-dependabot-config.mjs",
    "verify:packaged": "node scripts/verify-packaged-runtime.mjs",
    "verify:installers": "node scripts/verify-installers.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,html}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,html}\" \"tests/**/*.ts\""
  },
  "keywords": [
    "electron",
    "chatgpt",
    "openai",
    "openai-api",
    "whisper",
    "transcription",
    "speech-to-text",
    "desktop",
    "cloakbrowser"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "commonjs",
  "build": {
    "appId": "com.swimmwatch.gptvoice",
    "productName": "GPT-Voice",
    "copyright": "Copyright (c) 2026 Dmitry Vasiliev",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/cloakbrowser/**/*",
      "node_modules/tar/**/*",
      "node_modules/@isaacs/fs-minipass/**/*",
      "node_modules/chownr/**/*",
      "node_modules/minipass/**/*",
      "node_modules/minizlib/**/*",
      "node_modules/mkdirp/**/*",
      "node_modules/yallist/**/*",
      "node_modules/electron-log/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "build/generated/common/license.txt",
        "to": "LICENSE.txt"
      },
      {
        "from": ".cache/cloakbrowser",
        "to": "cloakbrowser"
      }
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": false,
      "grantFileProtocolExtraPrivileges": false
    },
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "executableName": "gpt-voice",
      "category": "Utility",
      "icon": "assets/icons",
      "synopsis": "Voice transcription through GPT web sessions and OpenAI API",
      "description": "GPT-Voice records speech on your desktop and sends it through an authenticated GPT web session or OpenAI API for fast transcription without a local model or GPU.",
      "vendor": "Dmitry Vasiliev",
      "maintainer": "Dmitry Vasiliev <contact.vasiliev.dmitry@gmail.com>",
      "desktop": {
        "entry": {
          "Name": "GPT-Voice",
          "GenericName": "Voice Transcriber",
          "Comment": "Transcribe speech through GPT web sessions or OpenAI API",
          "Keywords": "voice;transcription;speech;chatgpt;openai;whisper;",
          "StartupWMClass": "gpt-voice"
        }
      }
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "fpm": [
        "build/generated/linux/com.swimmwatch.gptvoice.metainfo.xml=/usr/share/metainfo/com.swimmwatch.gptvoice.metainfo.xml",
        "build/generated/linux/debian-copyright=/usr/share/doc/gpt-voice/copyright"
      ]
    },
    "rpm": {
      "packageCategory": "Utility",
      "depends": [
        "(libXtst or libXtst6)",
        "(libuuid or libuuid1)",
        "alsa-lib",
        "at-spi2-core",
        "gtk3",
        "libXScrnSaver",
        "libnotify",
        "mesa-libgbm",
        "nss",
        "xdg-utils"
      ],
      "fpm": [
        "build/generated/linux/com.swimmwatch.gptvoice.metainfo.xml=/usr/share/metainfo/com.swimmwatch.gptvoice.metainfo.xml",
        "build/generated/common/license.txt=/usr/share/licenses/gpt-voice/LICENSE.txt"
      ]
    },
    "appImage": {
      "license": "build/generated/common/license.txt"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "GPT-Voice",
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true,
      "legalTrademarks": "GPT-Voice is an independent project and is not affiliated with OpenAI."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "GPT-Voice",
      "shortcutName": "GPT-Voice",
      "uninstallDisplayName": "GPT-Voice",
      "deleteAppDataOnUninstall": false,
      "license": "build/generated/windows/license.txt"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "executableName": "GPT-Voice",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "identity": null,
      "extraResources": [
        {
          "from": "build/generated/macos/PrivacyInfo.xcprivacy",
          "to": "PrivacyInfo.xcprivacy"
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "CFBundleDisplayName": "GPT-Voice",
        "NSHumanReadableCopyright": "Copyright (c) 2026 Dmitry Vasiliev",
        "NSMicrophoneUsageDescription": "GPT-Voice uses the microphone to record speech for transcription."
      }
    },
    "dmg": {
      "title": "GPT-Voice ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "cloakbrowser": "0.4.8",
    "electron-log": "^5.4.4",
    "http-status-codes": "^2.3.0",
    "mmdb-lib": "^3.0.2",
    "playwright-core": "1.61.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "socks-proxy-agent": "^10.1.0"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.3",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "html-webpack-plugin": "^5.6.7",
    "prettier": "^3.9.4",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.6.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "yaml": "^2.9.0"
  }
}
