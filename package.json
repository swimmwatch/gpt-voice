{
  "name": "chatgpt-web-voice",
  "version": "1.0.0",
  "description": "Desktop voice transcriber with ChatGPT",
  "homepage": "https://github.com/swimmwatch/gpt-web-voice",
  "author": {
    "name": "Dmitry Vasiliev",
    "email": "contact.vasiliev.dmitry@gmail.com"
  },
  "main": "dist/main.js",
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "build:prod": "cross-env NODE_ENV=production webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "start:prod": "npm run build:prod && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "prepare:cloakbrowser": "node scripts/prepare-cloakbrowser.mjs",
    "smoke:cloakbrowser": "node scripts/smoke-cloakbrowser.mjs",
    "pack": "npm run build:prod && npm run prepare:cloakbrowser && electron-builder --dir",
    "dist": "npm run build:prod && npm run prepare:cloakbrowser && electron-builder",
    "dist:linux": "npm run build:prod && npm run prepare:cloakbrowser -- --target=linux && electron-builder --linux",
    "dist:win": "npm run build:prod && npm run prepare:cloakbrowser -- --target=win32 && electron-builder --win",
    "dist:mac": "npm run build:prod && npm run prepare:cloakbrowser -- --target=darwin && electron-builder --mac",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,html}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,html}\""
  },
  "keywords": [],
  "license": "ISC",
  "type": "commonjs",
  "build": {
    "appId": "com.webvoice.app",
    "productName": "WebVoice",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/cloakbrowser/**/*",
      "node_modules/tar/**/*",
      "node_modules/@isaacs/fs-minipass/**/*",
      "node_modules/chownr/**/*",
      "node_modules/minipass/**/*",
      "node_modules/minizlib/**/*",
      "node_modules/mkdirp/**/*",
      "node_modules/yallist/**/*",
      "node_modules/electron-log/**/*"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": ".cache/cloakbrowser",
        "to": "cloakbrowser"
      }
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "icon": "assets/icon.png",
      "maintainer": "Dmitry Vasiliev <contact.vasiliev.dmitry@gmail.com>"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities"
    }
  },
  "dependencies": {
    "cloakbrowser": "0.3.28",
    "electron-log": "^5.4.3",
    "http-status-codes": "^2.3.0",
    "playwright-core": "1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "html-webpack-plugin": "^5.6.6",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "sass-loader": "^16.0.7",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.0"
  }
}
