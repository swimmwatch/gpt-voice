{
  "name": "gpt-voice",
  "version": "1.4.0",
  "private": true,
  "description": "Desktop voice transcription app powered by GPT web sessions and OpenAI API.",
  "homepage": "https://github.com/swimmwatch/gpt-voice",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/swimmwatch/gpt-voice.git"
  },
  "bugs": {
    "url": "https://github.com/swimmwatch/gpt-voice/issues"
  },
  "author": {
    "name": "Dmitry Vasiliev",
    "email": "contact.vasiliev.dmitry@gmail.com"
  },
  "main": "dist/main.js",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "build": "webpack --config webpack.config.js",
    "clean:dist": "node scripts/clean-dist.mjs",
    "build:prod": "npm run clean:dist && cross-env NODE_ENV=production webpack --config webpack.config.js",
    "start": "npm run build && electron .",
    "start:prod": "npm run build:prod && electron .",
    "dev": "webpack --config webpack.config.js --watch",
    "landing:sync-media": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/sync-public-assets.ts",
    "landing:generate-locales": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/generate-locales.ts",
    "landing:generate-txt": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/generate-txt-files.ts",
    "landing:dev": "vite --config vite.landing.config.ts",
    "landing:typecheck": "tsc --noEmit -p tsconfig.landing.json && tsc --noEmit -p tsconfig.landing.node.json",
    "landing:lint": "eslint --no-error-on-unmatched-pattern src/landing-page tests/landing-page vite.landing.config.ts playwright.landing.config.ts",
    "landing:format": "prettier --no-error-on-unmatched-pattern --write \"src/landing-page/**/*.{ts,tsx,css,html,json}\" \"tests/landing-page/**/*.{ts,tsx}\" vite.landing.config.ts playwright.landing.config.ts tsconfig.landing*.json",
    "landing:format:check": "prettier --no-error-on-unmatched-pattern --check \"src/landing-page/**/*.{ts,tsx,css,html,json}\" \"tests/landing-page/**/*.{ts,tsx}\" vite.landing.config.ts playwright.landing.config.ts tsconfig.landing*.json",
    "landing:test": "vitest --config vite.landing.config.ts",
    "landing:test:e2e": "playwright test --config playwright.landing.config.ts",
    "landing:build": "vite build --config vite.landing.config.ts",
    "landing:verify:seo": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/verify-seo.ts",
    "landing:verify:a11y": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/verify-accessibility.ts",
    "landing:verify:browser-support": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/verify-browser-support.ts",
    "landing:verify:media": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/verify-media.ts",
    "landing:verify:sizes": "tsx --tsconfig tsconfig.landing.node.json src/landing-page/build/verify-sizes.ts",
    "landing:preview": "vite preview --config vite.landing.config.ts",
    "ci:install": "node scripts/ci-install.mjs",
    "apply:release-version": "node scripts/apply-release-version.mjs",
    "prepare:cloakbrowser": "node scripts/prepare-cloakbrowser.mjs",
    "generate:package-metadata": "node scripts/generate-package-metadata.mjs",
    "smoke:cloakbrowser": "node scripts/smoke-cloakbrowser.mjs",
    "smoke:fedora": "node scripts/build-fedora-release.mjs --mode=smoke",
    "collect:release-artifacts": "node scripts/collect-release-artifacts.mjs",
    "pack": "npm run build:prod && npm run prepare:cloakbrowser && npm run generate:package-metadata && electron-builder --dir",
    "dist": "npm run build:prod && npm run prepare:cloakbrowser && npm run generate:package-metadata && electron-builder",
    "dist:linux": "npm run build:prod && npm run prepare:cloakbrowser -- --target=linux && npm run generate:package-metadata && electron-builder --linux",
    "dist:fedora": "node scripts/build-fedora-release.mjs --mode=release",
    "dist:win": "npm run build:prod && npm run prepare:cloakbrowser -- --target=win32 && npm run generate:package-metadata && electron-builder --win",
    "dist:mac": "npm run build:prod && npm run prepare:cloakbrowser -- --target=darwin && npm run generate:package-metadata && electron-builder --mac",
    "lint": "eslint src/ tests/ scripts/ eslint.config.mjs webpack.config.js",
    "lint:fix": "eslint src/ tests/ scripts/ eslint.config.mjs webpack.config.js --fix",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "node --import tsx --test \"tests/**/*.test.ts\"",
    "test:watch": "node --import tsx --test --watch \"tests/**/*.test.ts\"",
    "test:types": "tsc --noEmit -p tsconfig.test.json",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "audit:all": "npm audit --audit-level=high",
    "measure:size": "node scripts/build-size-cli.mjs measure",
    "measure:startup": "node scripts/measure-startup.mjs",
    "verify:size": "node scripts/build-size-cli.mjs verify",
    "validate:dependabot": "node scripts/validate-dependabot-config.mjs",
    "verify:packaged": "node scripts/verify-packaged-runtime.mjs",
    "verify:installers": "node scripts/verify-installers.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx,scss,html}\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,scss,html}\" \"tests/**/*.ts\""
  },
  "keywords": [
    "electron",
    "chatgpt",
    "openai",
    "openai-api",
    "whisper",
    "transcription",
    "speech-to-text",
    "desktop",
    "cloakbrowser"
  ],
  "license": "PolyForm-Noncommercial-1.0.0",
  "type": "commonjs",
  "build": {
    "appId": "com.swimmwatch.gptvoice",
    "productName": "GPT-Voice",
    "copyright": "Copyright (c) 2026 Dmitry Vasiliev",
    "asar": true,
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "node_modules/playwright-core/**/*",
      "node_modules/cloakbrowser/**/*",
      "node_modules/tar/**/*",
      "node_modules/@isaacs/fs-minipass/**/*",
      "node_modules/chownr/**/*",
      "node_modules/minipass/**/*",
      "node_modules/minizlib/**/*",
      "node_modules/mkdirp/**/*",
      "node_modules/yallist/**/*",
      "node_modules/electron-log/**/*",
      "!**/*.map",
      "!**/*.d.ts",
      "!**/*.d.mts",
      "!**/*.d.cts",
      "!**/{__test__,__tests__,fixture,fixtures,test,tests}/**"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets",
        "filter": [
          "icon.png",
          "icons/**/*.png",
          "tray-icon-idle.png",
          "tray-icon-paused.png",
          "tray-icon-prettifying.png",
          "tray-icon-processing.png",
          "tray-icon-recording.png"
        ]
      },
      {
        "from": "build/generated/common/license.txt",
        "to": "LICENSE.txt"
      },
      {
        "from": ".cache/cloakbrowser",
        "to": "cloakbrowser"
      }
    ],
    "electronFuses": {
      "runAsNode": false,
      "enableCookieEncryption": true,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "enableEmbeddedAsarIntegrityValidation": true,
      "onlyLoadAppFromAsar": true,
      "loadBrowserProcessSpecificV8Snapshot": false,
      "grantFileProtocolExtraPrivileges": false
    },
    "electronLanguages": [
      "en-US",
      "en-GB",
      "ru",
      "uk"
    ],
    "linux": {
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "executableName": "gpt-voice",
      "category": "Utility",
      "icon": "assets/icons",
      "synopsis": "Voice transcription through GPT web sessions and OpenAI API",
      "description": "GPT-Voice records speech on your desktop and sends it through an authenticated GPT web session or OpenAI API for fast transcription without a local model or GPU.",
      "vendor": "Dmitry Vasiliev",
      "maintainer": "Dmitry Vasiliev <contact.vasiliev.dmitry@gmail.com>",
      "desktop": {
        "entry": {
          "Name": "GPT-Voice",
          "GenericName": "Voice Transcriber",
          "Comment": "Transcribe speech through GPT web sessions or OpenAI API",
          "Keywords": "voice;transcription;speech;chatgpt;openai;whisper;",
          "StartupWMClass": "gpt-voice"
        }
      }
    },
    "deb": {
      "packageCategory": "utils",
      "priority": "optional",
      "fpm": [
        "build/generated/linux/com.swimmwatch.gptvoice.metainfo.xml=/usr/share/metainfo/com.swimmwatch.gptvoice.metainfo.xml",
        "build/generated/linux/debian-copyright=/usr/share/doc/gpt-voice/copyright"
      ]
    },
    "rpm": {
      "packageCategory": "Utility",
      "depends": [
        "(libXtst or libXtst6)",
        "(libuuid or libuuid1)",
        "alsa-lib",
        "at-spi2-core",
        "gtk3",
        "libXScrnSaver",
        "libnotify",
        "mesa-libgbm",
        "nss",
        "xdg-utils"
      ],
      "fpm": [
        "build/generated/linux/com.swimmwatch.gptvoice.metainfo.xml=/usr/share/metainfo/com.swimmwatch.gptvoice.metainfo.xml",
        "build/generated/common/license.txt=/usr/share/licenses/gpt-voice/LICENSE.txt"
      ]
    },
    "appImage": {
      "license": "build/generated/common/license.txt"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "executableName": "GPT-Voice",
      "icon": "assets/icon.png",
      "requestedExecutionLevel": "asInvoker",
      "signAndEditExecutable": true,
      "legalTrademarks": "GPT-Voice is an independent project and is not affiliated with OpenAI."
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "menuCategory": "GPT-Voice",
      "shortcutName": "GPT-Voice",
      "uninstallDisplayName": "GPT-Voice",
      "deleteAppDataOnUninstall": false,
      "license": "build/generated/windows/license.txt"
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "executableName": "GPT-Voice",
      "icon": "assets/icon.png",
      "category": "public.app-category.utilities",
      "identity": null,
      "extraResources": [
        {
          "from": "build/generated/macos/PrivacyInfo.xcprivacy",
          "to": "PrivacyInfo.xcprivacy"
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "CFBundleDisplayName": "GPT-Voice",
        "NSHumanReadableCopyright": "Copyright (c) 2026 Dmitry Vasiliev",
        "NSMicrophoneUsageDescription": "GPT-Voice uses the microphone to record speech for transcription."
      }
    },
    "dmg": {
      "title": "GPT-Voice ${version}",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "dependencies": {
    "cloakbrowser": "0.4.10",
    "electron-log": "^5.4.4",
    "mmdb-lib": "^3.0.2",
    "playwright-core": "1.61.1",
    "socks-proxy-agent": "^10.1.0"
  },
  "devDependencies": {
    "@electron/asar": "^3.4.1",
    "@electron/fuses": "^2.1.3",
    "@eslint-react/eslint-plugin": "^5.10.0",
    "@eslint/js": "^10.0.1",
    "@fontsource-variable/jetbrains-mono": "5.2.8",
    "@fontsource-variable/noto-sans-devanagari": "5.2.8",
    "@fontsource-variable/noto-sans-jp": "5.2.10",
    "@fontsource-variable/noto-sans-sc": "5.2.10",
    "@fontsource-variable/ubuntu-sans": "5.2.10",
    "@playwright/test": "1.61.1",
    "@radix-ui/react-alert-dialog": "^1.1.19",
    "@radix-ui/react-collapsible": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-navigation-menu": "1.2.18",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slider": "^1.4.3",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/vite": "4.3.2",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-legacy": "8.2.0",
    "@vitejs/plugin-react": "6.0.3",
    "ajv": "^8.20.0",
    "axe-core": "4.12.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "core-js": "3.49.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-jsdoc": "^63.0.13",
    "eslint-plugin-n": "^18.2.1",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-sonarjs": "^4.1.0",
    "eslint-plugin-unicorn": "^71.1.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "filesize": "^11.0.19",
    "html-minifier-terser": "7.2.0",
    "html-validate": "11.5.6",
    "html-webpack-plugin": "^5.6.7",
    "http-status-codes": "^2.3.0",
    "jsdom": "29.1.1",
    "lighthouse": "13.4.0",
    "lightningcss": "1.32.0",
    "lucide-react": "1.24.0",
    "mini-css-extract-plugin": "^2.10.2",
    "plyr": "3.8.4",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sass": "^1.101.0",
    "sass-loader": "^17.0.0",
    "schema-dts": "2.0.0",
    "sharp": "0.35.3",
    "sonner": "^2.0.7",
    "style-loader": "^4.0.0",
    "subset-font": "2.5.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "4.3.2",
    "terser": "5.49.0",
    "ts-loader": "^9.6.2",
    "tsx": "^4.22.5",
    "typescript": "6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0",
    "yaml": "^2.9.0"
  }
}
