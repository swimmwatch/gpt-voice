{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "react-jsx",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@landing/*": ["./src/landing-page/*"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020",
    "types": ["vite/client"]
  },
  "exclude": ["node_modules", "build", "dist", "src/landing-page/build"],
  "include": ["src/landing-page/**/*.ts", "src/landing-page/**/*.tsx"]
}
